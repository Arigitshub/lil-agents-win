{
  "name": "lil-agents-win",
  "version": "1.0.0",
  "description": "Tiny AI companions that live on your Windows taskbar",
  "author": "Arigitshub",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.lilagents.win",
    "productName": "lil agents",
    "win": {
      "target": "nsis",
      "icon": "public/assets/hero.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "public/assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  }
}
